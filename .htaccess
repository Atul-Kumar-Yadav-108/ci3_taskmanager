Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /taskmanager/

    # Allow direct access to existing files and directories
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route everything else through CodeIgniter's index.php
    RewriteRule ^(.*)$ index.php/$1 [L]
</IfModule>

<IfModule !mod_rewrite.c>
    # If mod_rewrite is not available, use query string routing
    ErrorDocument 404 /taskmanager/index.php
</IfModule>
